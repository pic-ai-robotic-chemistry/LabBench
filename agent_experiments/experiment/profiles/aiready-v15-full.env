# Full AIREADY V15 matrix profile.
#
# Usage:
#   bash experiment/bin/aiready_workflow.sh all-with-scoring \
#     --profile experiment/profiles/aiready-v15-full.env \
#     --run-label v15-full-$(date +%Y%m%d-%H%M%S)
#
# This profile contains only public, reproducible experiment parameters.
# Put real secrets in the repository-level `.env` file. The repository
# `.gitignore` keeps local credentials and generated runtime outputs untracked.

# Benchmark input. The prepare stage parses SOURCE_DOCX into A01-G08 task
# instructions.
BENCHMARK_VERSION=v15
SOURCE_DOCX=Benchmark_V15.docx

# Full V15 task set. Edit TASK_IDS to run only one module or to rerun selected
# tasks.
# Example: TASK_IDS="A01 A02 E01"
TASK_IDS="A01 A02 A03 A04 B01 B02 B03 B04 C01 C02 D01 D02 E01 E02 E03 E04 E05 E06 E07 E08 F01 F02 F03 F04 G01 G02 G03 G04 G05 G06 G07 G08"

# Agent harness. The prepare stage generates one Harbor config for each
# harness/model/skill combination. The public profile uses openclaw as the
# reproducible baseline.
HARNESSES="openclaw"

# Model keys come from the MODELS table in tools/prepare_aiready_experiment.py.
# The public profile uses the neutral model_a alias. Fill
# AIREADY_MODEL_A_NAME, AIREADY_MODEL_A_BASE_URL, and the matching harness API
# key in `.env`. Adding or removing MODELS changes the trial, image, and config
# counts linearly.
MODELS="model_a"

# Local skill directory: aiready/aiready_skill_7.6 (not distributed).
# The workflow uses the prepare_aiready_experiment.py alias aiready-skill-7.6.
# To run a custom skill directory, register it with EXTRA_SKILL_VARIANTS and
# select its alias through SKILL_VARIANTS.
SKILL_VARIANTS="aiready-skill-7.6"
EXTRA_SKILL_VARIANTS=""

# Image naming and push settings. Full remote runs usually push images to a
# registry so workers can pull them.
# REGISTRY_PREFIX example: harbor.example.com/<namespace>/aiready-v15
REGISTRY_PREFIX="harbor.example.com/namespace/aiready-v15"
IMAGE_TAG="v15"
BASE_TAG="v15"
FINAL_TAG="v15"
PUSH=1
PUSH_METHOD=docker
SKIP_REMOTE_EXISTING=1

# Runtime scale. N_ATTEMPTS is the repeat count per config.
# N_CONCURRENT_TRIALS is the number of concurrent trials inside each Harbor
# config. AGENT_TIMEOUT_SEC is the maximum runtime per agent.
N_ATTEMPTS=1
N_CONCURRENT_TRIALS=10
AGENT_TIMEOUT_SEC=1800
AIREADY_ENV_CPUS=2
AIREADY_ENV_MEMORY_MB=12288
AIREADY_ENV_STORAGE_MB=20480

# Stage toggles. The all and all-with-scoring commands read these flags.
# Individual stage commands do not depend on them.
BUILD_IMAGES=1
RUN_EXPERIMENTS=1

# Real dispatch-rate statistics:
#   none      Disable dispatch statistics.
#   no-verify Extract candidate task IDs from trial outputs only. Use this when
#             verification endpoint access is unavailable.
#   verify    Call the verification endpoint configured in `.env`.
DISPATCH_STATS_MODE=no-verify

# Scoring pipeline. Use all-with-scoring for the complete workflow. To run only
# the experiment first, set SCORING_RUN_JOBS=0 or use the all command.
SCORING_ENABLED=1
SCORING_BUILD_IMAGES=1
SCORING_RUN_JOBS=1

# Judge harness/model. This is independent from the experiment harness: it
# controls who scores the plans, not who generates them. The public profile uses
# judge_a; put the real judge model and key in `.env`.
SCORING_HARNESSES="codex"
SCORING_JUDGES="judge_a"

# Scoring dimensions. These correspond to the three primary dimensions in
# scoring/aiready_scoring_rubric_en.md.
SCORING_DIMENSIONS="physical_implementability workflow_completeness design_rationality"

# Skill root mounted for judge reference. It must be supplied locally.
SCORING_SKILLS_DIR="aiready/aiready_skill_7.6"
SCORING_SKIP_MISSING_FINAL_PLAN=1
