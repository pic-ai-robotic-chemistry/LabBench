# Minimal AIREADY V15 smoke profile.
#
# Usage:
#   bash experiment/bin/aiready_workflow.sh all \
#     --profile experiment/profiles/aiready-v15-smoke.env \
#     --run-label smoke-a01
#
# This profile contains only public, reproducible experiment parameters.
# Put Harbor credentials, model endpoints, AICHEM tokens, and every other secret
# in the repository-level `.env` file. Never put secrets in this profile.

# Benchmark input. SOURCE_DOCX is parsed by the prepare stage into task
# instructions.
BENCHMARK_VERSION=v15
SOURCE_DOCX=Benchmark_V15.docx

# Experiment matrix. The approximate trial count is:
#   number of TASK_IDS * number of HARNESSES * number of MODELS *
#   number of SKILL_VARIANTS * N_ATTEMPTS
# The smoke profile runs one A01/openclaw/model_a/skill7.6 trial to validate
# the pipeline quickly.
TASK_IDS="A01"
HARNESSES="openclaw"
MODELS="model_a"

# Local skill directory: aiready/aiready_skill_7.6 (not distributed).
# The workflow uses the prepare_aiready_experiment.py alias aiready-skill-7.6.
# To run a custom skill directory without editing the prepare script, use:
#   EXTRA_SKILL_VARIANTS="my-skill=aiready/my_new_skill"
#   SKILL_VARIANTS="my-skill"
SKILL_VARIANTS="aiready-skill-7.6"
EXTRA_SKILL_VARIANTS=""

# Image naming. REGISTRY_PREFIX controls the Docker repository prefix.
# IMAGE_TAG, BASE_TAG, and FINAL_TAG control the base, harness, task, and final
# image tags. The smoke profile builds local images and does not push them.
REGISTRY_PREFIX="aiready-local/aiready"
IMAGE_TAG="smoke"
BASE_TAG="smoke"
FINAL_TAG="smoke"
PUSH=0
PUSH_METHOD=docker
SKIP_REMOTE_EXISTING=0

# Runtime resources and retry scale. A very small AGENT_TIMEOUT_SEC can stop an
# agent before it writes final_plan.json. The smoke profile uses 120 seconds only
# for quick pipeline checks; real runs should use the full profile value or
# higher.
N_ATTEMPTS=1
N_CONCURRENT_TRIALS=1
AGENT_TIMEOUT_SEC=120
AIREADY_ENV_CPUS=2
AIREADY_ENV_MEMORY_MB=12288
AIREADY_ENV_STORAGE_MB=20480

# Stage toggles. The all and all-with-scoring commands read these flags.
# Individual prepare/build/run/collect commands do not depend on them.
BUILD_IMAGES=1
RUN_EXPERIMENTS=1

# Real dispatch-rate statistics:
#   none      Disable dispatch statistics.
#   no-verify Extract candidate task IDs from trial outputs without calling the
#             verification endpoint.
#   verify    Call the verification endpoint configured in `.env`.
DISPATCH_STATS_MODE=no-verify

# Scoring pipeline toggles. all-with-scoring runs the experiment and collect
# stages, prepares judge tasks, builds judge images, runs judge containers, and
# aggregates score.json outputs.
SCORING_ENABLED=1
SCORING_BUILD_IMAGES=1
SCORING_RUN_JOBS=1

# Judge harness/model. The smoke profile uses the neutral judge_a configuration.
# Put the real judge model name, base URL, and API key in `.env`.
SCORING_HARNESSES="codex"
SCORING_JUDGES="judge_a"

# Scoring dimensions. These correspond to the three primary dimensions in
# scoring/aiready_scoring_rubric_en.md.
SCORING_DIMENSIONS="physical_implementability workflow_completeness design_rationality"

# Skill root mounted for judge reference. It must be supplied locally.
SCORING_SKILLS_DIR="aiready/aiready_skill_7.6"
SCORING_SKIP_MISSING_FINAL_PLAN=1
